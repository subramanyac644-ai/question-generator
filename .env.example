# ==============================================================================
# QUESTION GENERATOR PLATFORM ENVIRONMENT VARIABLES BLUEPRINT
# ==============================================================================

# 1. DATABASE CONFIGURATION (Supabase PostgreSQL Connection Pooling Setup)
# DATABASE_URL: Connect to Supabase using transaction pooler (Session mode, port 6543)
DATABASE_URL="postgresql://postgres.your_project_id:your_password@aws-0-your_region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: Connect to Supabase directly for running migrations/seeding (Direct mode, port 5432)
DIRECT_URL="postgresql://postgres.your_project_id:your_password@aws-0-your_region.pooler.supabase.com:5432/postgres"

# 2. AUTHENTICATION CONFIGURATION
# Used by the @qgp/auth library for JWT sign/verify operations
JWT_SECRET="generate_a_secure_32_character_random_hex_string_for_production"

# 3. AI GENERATOR ENGINE CONFIGURATION (OpenRouter API)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Default LLM model to request questions from
OPENROUTER_MODEL="google/gemini-2.5-flash"

# 4. APP PORTS AND SITE METADATA
PORT=5000
SITE_URL="http://localhost:3000"
SITE_NAME="Question Generator Platform"
